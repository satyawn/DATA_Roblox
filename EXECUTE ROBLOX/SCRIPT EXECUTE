-- HITBOX LOOP
task.spawn(function()
    while true do
        if hitboxEnabled then
            for m,d in pairs(activeNPCs) do
                if m.Parent then applyHitbox(m,d.root) end
            end
        else
            for m,_ in pairs(originalSizes) do restoreHitbox(m) end
        end
        task.wait(0.1)
    end
end)

-- FAST SCAN LOOP
task.spawn(function()
    while true do
        if fastScanEnabled then
            local items=Workspace:GetDescendants()
            for i,m in ipairs(items) do
                if m:IsA("Model") and not activeNPCs[m] and isValidNPC(m) then
                    addNPC(m)
                end
                if i%300==0 then task.wait() end
            end
            task.wait(0.001)
        else
            task.wait(0.5)
        end
    end
end)

