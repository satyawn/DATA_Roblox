-- NPC VALIDATION (STRICTER & FASTER)
local function isValidNPC(m)
    if not m or not m.Parent then return false end
    local name = m.Name:lower()
    if string.find(name,"zombie") then return true end
    -- Cek folder atau tag tertentu biasanya lebih cepat daripada loop children
    if m:FindFirstChild("Humanoid") then return true end 
    return false
end

-- ADD NPC (OPTIMIZED)
local function addNPC(m)
    if activeNPCs[m] then return end
    
    local head = m:FindFirstChild("Head")
    local root = m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("UpperTorso")
    
    if root then
        activeNPCs[m] = {head = head or root, root = root}

        if wallEnabled then
            local part = head or root
            if part and not part:FindFirstChild("Wall_Box") then
                local s = Instance.new("SphereHandleAdornment")
                s.Name = "Wall_Box"
                s.Radius = 1.2
                s.Adornee = part
                s.AlwaysOnTop = true
                s.Transparency = 0.5 -- Sedikit lebih transparan biar FPS naik
                s.Color3 = name:find("zombie") and Color3.fromRGB(255,0,0) or Color3.fromRGB(0,255,0)
                s.Parent = part
                trackedParts[part] = s
            end
        end
    end
end

-- VISIBILITY CHECK (RAYCAST OPTIMIZED)
local function isVisible(target)
    if not target or not target:FindFirstChild("Head") then return false end
    local headPos = target.Head.Position
    local camPos = camera.CFrame.Position
    local rayParam = RaycastParams.new()
    rayParam.FilterDescendantsInstances = {localPlayer.Character, target}
    rayParam.FilterType = Enum.RaycastFilterType.Exclude
    
    local result = Workspace:Raycast(camPos, (headPos - camPos).Unit * 500, rayParam)
    return result == nil
end

-- TARGETING (OPTIMIZED LOOP)
local function getClosestNPC()
    local closest, dist = nil, fovRadius
    for m, d in pairs(activeNPCs) do
        if m and m.Parent and d.head then
            local pos, onScreen = camera:WorldToViewportPoint(d.head.Position)
            if onScreen then
                local d2 = (Vector2.new(pos.X, pos.Y) - centerPosition).Magnitude
                if d2 <= fovRadius and d2 < dist then
                    if isVisible(m) then
                        closest = m
                        dist = d2
                    end
                end
            end
        else
            activeNPCs[m] = nil -- Auto clean up
        end
    end
    return closest
end

-- SILENT AIM HOOK
task.spawn(function()
    pcall(function()
        -- Gunakan method yang lebih aman/cepat jika tersedia
        local func = filtergc('function',{Name='GetMuzzleCFrame'},true)
        if func then
            local old; old = hookfunction(func, function(self, cast)
                local origin, barrel, cam = old(self, cast)
                if silentAimEnabled then
                    local npc = getClosestNPC()
                    if npc and npc:FindFirstChild("Head") then
                        return CFrame.new(origin.Position, npc.Head.Position), barrel, cam
                    end
                end
                return origin, barrel, cam
            end)
        end
    end)
end)

