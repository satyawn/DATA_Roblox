-- NPC VALID
local function isValidNPC(m)
    if not m or not m.Parent then return false end
    local name = m.Name:lower()
    if string.find(name,"zombie") then return true end
    if m.Name == "Male" then
        for _,c in ipairs(m:GetChildren()) do
            if c.Name:sub(1,3) == "AI_" then return true end
        end
    end
    return false
end

-- ADD NPC (OPTIMIZED ESP DISTANCE)
local function addNPC(m)
    if activeNPCs[m] or not isValidNPC(m) then return end
    local head = m:FindFirstChild("Head")
    local root = m:FindFirstChild("HumanoidRootPart") or m:FindFirstChild("UpperTorso")
    if root then
        activeNPCs[m] = {head = head or root, root = root}

        if wallEnabled then
            local part = head or root
            if part and not part:FindFirstChild("Wall_Box") then
                local dist = (camera.CFrame.Position - part.Position).Magnitude
                if dist <= maxDistance then
                    local s = Instance.new("SphereHandleAdornment")
                    s.Name = "Wall_Box"
                    s.Radius = 1.2
                    s.Adornee = part
                    s.AlwaysOnTop = true
                    s.Transparency = 0.3
                    s.Color3 = string.find(m.Name:lower(),"zombie") and Color3.fromRGB(255,0,0) or Color3.fromRGB(0,255,0)
                    s.Parent = part
                    trackedParts[part] = s
                end
            end
        end

        if outlineEnabled then
            if not m:FindFirstChild("ESP_Outline") then
                local h = Instance.new("Highlight")
                h.Name = "ESP_Outline"
                h.FillTransparency = 1
                h.OutlineColor = string.find(m.Name:lower(),"zombie") and Color3.fromRGB(255,0,0) or Color3.fromRGB(0,255,0)
                h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                h.Parent = m
            end
        end
    end
end

-- VISIBILITY
local function isVisible(target)
    if not target or not target:FindFirstChild("Head") then return false end
    local ignore = {localPlayer.Character, target}
    return #camera:GetPartsObscuringTarget({target.Head.Position}, ignore) == 0
end

-- CLOSEST NPC
local function getClosestNPC()
    local closest, dist = nil, fovRadius
    for m,d in pairs(activeNPCs) do
        if m.Parent and d.head then
            local pos, onScreen = camera:WorldToViewportPoint(d.head.Position)
            if onScreen then
                local d2 = (Vector2.new(pos.X,pos.Y) - centerPosition).Magnitude
                if d2 <= fovRadius and d2 < dist and isVisible(m) then
                    closest = m
                    dist = d2
                end
            end
        end
    end
    return closest
end

-- HITBOX (OPTIMIZED)
local function applyHitbox(model, root)
    local dist = (camera.CFrame.Position - root.Position).Magnitude
    if dist > hitboxDistance then return end

    if not originalSizes[model] then originalSizes[model] = root.Size end

    if root.Size.X ~= hitboxSize then
        root.Size = Vector3.new(hitboxSize,hitboxSize,hitboxSize)
    end

    root.Transparency = showHitbox and 0.8 or 1
    if showHitbox then
        root.Material = Enum.Material.Neon
        root.Color = Color3.fromRGB(255,0,0)
    end
end

local function restoreHitbox(model)
    local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("UpperTorso")
    if root and originalSizes[model] then
        root.Size = originalSizes[model]
        root.Transparency = 1
    end
end

-- CLEAR ESP
local function clearSpheres()
    for _,s in pairs(trackedParts) do
        if s then s:Destroy() end
    end
    trackedParts = {}
end

-- FAST SCAN OPTIMIZED
local scanIndex = 1
local cachedItems = {}

task.spawn(function()
    while true do
        if fastScanEnabled then
            if #cachedItems == 0 then
                cachedItems = Workspace:GetDescendants()
                scanIndex = 1
            end

            for i = 1, 200 do
                local m = cachedItems[scanIndex]
                if not m then break end

                if m:IsA("Model") and not activeNPCs[m] and isValidNPC(m) then
                    addNPC(m)
                end

                scanIndex += 1
            end

            if scanIndex > #cachedItems then
                cachedItems = {}
            end

            task.wait(0.03)
        else
            task.wait(0.5)
        end
    end
end)

-- HITBOX LOOP
task.spawn(function()
    while true do
        if hitboxEnabled then
            for m,d in pairs(activeNPCs) do
                if m.Parent then applyHitbox(m,d.root) end
            end
            task.wait(0.15)
        else
            for m,_ in pairs(originalSizes) do restoreHitbox(m) end
            task.wait(0.3)
        end
    end
end)

-- RENDER OPTIMIZED
local lastUpdate = 0

RunService.RenderStepped:Connect(function()
    centerPosition = camera.ViewportSize/2

    if fovCircle then
        fovCircle.Visible = showFovCircle and silentAimEnabled
        fovCircle.Position = centerPosition
        fovCircle.Radius = fovRadius
    end

    if tick() - lastUpdate > 0.1 then
        lastUpdate = tick()

        if fullBrightEnabled then
            lighting.Brightness = 2
            lighting.Ambient = Color3.new(1,1,1)
            lighting.OutdoorAmbient = Color3.new(1,1,1)
        end

        if alwaysDayEnabled then
            lighting.ClockTime = 12
        end
    end
end)

