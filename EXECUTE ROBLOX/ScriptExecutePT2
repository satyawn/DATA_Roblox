-- HITBOX
local function applyHitbox(model, root)
    if not originalSizes[model] then originalSizes[model] = root.Size end
    local newSize = Vector3.new(hitboxSize,hitboxSize,hitboxSize)
    root.Size = newSize
    root.Transparency = showHitbox and 0.8 or 1
end

local function restoreHitbox(model)
    local root = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("UpperTorso")
    if root and originalSizes[model] then
        root.Size = originalSizes[model]
        root.Transparency = 1
    end
end

local function clearSpheres()
    for _,s in pairs(trackedParts) do
        if s then s:Destroy() end
    end
    trackedParts = {}
end

